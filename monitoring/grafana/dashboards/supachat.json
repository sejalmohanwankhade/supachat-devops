{
  "title": "SupaChat Overview",
  "uid": "supachat-overview",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "title": "Request Rate", "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(supachat_requests_total[5m]))", "legendFormat": "req/s" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green" }] } } }
    },
    {
      "id": 2, "title": "Error Rate", "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(supachat_requests_total{status=~'5..'}[5m])) / sum(rate(supachat_requests_total[5m])) * 100", "legendFormat": "%" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "red" }] } } }
    },
    {
      "id": 3, "title": "P95 Latency (chat)", "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(supachat_request_duration_seconds_bucket{endpoint='/api/chat'}[5m]))", "legendFormat": "p95" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4, "title": "Active Connections", "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "supachat_active_connections", "legendFormat": "" }]
    },
    {
      "id": 5, "title": "Queries Processed", "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(increase(supachat_queries_total[1h]))", "legendFormat": "last 1h" }]
    },
    {
      "id": 6, "title": "Query Success Rate", "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "sum(rate(supachat_queries_total{status='success'}[10m])) / sum(rate(supachat_queries_total[10m])) * 100", "legendFormat": "%" }],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 80, "color": "green" }] } } }
    },
    {
      "id": 7, "title": "Request Rate Over Time", "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(supachat_requests_total[2m]))", "legendFormat": "Total" },
        { "expr": "sum(rate(supachat_requests_total{status=~'2..'}[2m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(supachat_requests_total{status=~'5..'}[2m]))", "legendFormat": "5xx" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 8, "title": "Response Time Percentiles", "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(supachat_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(supachat_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(supachat_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9, "title": "CPU Usage", "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[2m])) * 100)", "legendFormat": "CPU %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
    },
    {
      "id": 10, "title": "Memory Usage", "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "Memory %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
    },
    {
      "id": 11, "title": "LLM Processing Time", "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(supachat_llm_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(supachat_llm_duration_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12, "title": "Container Memory", "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        { "expr": "container_memory_usage_bytes{name=~'supachat-.*'}", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}

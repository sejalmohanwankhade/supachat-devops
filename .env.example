# SupaChat Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to git

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://YOUR_EC2_IP

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=changeme_in_production

# ── CI/CD (set in GitHub Secrets, not here) ───────────────────────────────────
# EC2_HOST=your.ec2.ip.address
# EC2_USER=ubuntu
# EC2_SSH_KEY=<your private key>
